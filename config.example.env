# Copy or source this file before running touchdeck-prototype.
#
# Example:
#   set -a
#   . /home/disk/Projects/touchdeck-prototype/config.example.env
#   set +a
#   cargo run --release

# Main config file. If unset, ./touchdeck.toml is loaded when it exists.
# TOUCHDECK_CONFIG=/home/disk/Projects/touchdeck-prototype/touchdeck.example.toml

# Optional raw XKB keymap file for the Wayland virtual keyboard.
# TOUCHDECK_XKB_KEYMAP=/path/to/keymap.xkb

# Niri actions are sent directly to the socket in $NIRI_SOCKET.
# This must be set by the niri session; there is no command fallback.

# Built-in niri gesture actions. Set any action to an empty value to disable it.
TOUCHDECK_ACTION_SWIPE_LEFT=focus-column-left
TOUCHDECK_ACTION_SWIPE_RIGHT=focus-column-right
TOUCHDECK_ACTION_SWIPE_UP=focus-workspace-up
TOUCHDECK_ACTION_SWIPE_DOWN=focus-workspace-down
TOUCHDECK_ACTION_TWO_FINGER_TAP=toggle-overview

# Gesture thresholds.
TOUCHDECK_TAP_RADIUS=48
TOUCHDECK_TWO_FINGER_TAP_MS=350
TOUCHDECK_EXIT_TAP_MS=450
TOUCHDECK_HOLD_MS=180
TOUCHDECK_DOUBLE_TAP_MS=280
TOUCHDECK_SWIPE_THRESHOLD_RATIO=0.08
TOUCHDECK_SWIPE_THRESHOLD_MIN=64
TOUCHDECK_SWIPE_THRESHOLD_MAX=140

# Debug visibility. 0 is fully transparent. 64 is faintly visible.
# TOUCHDECK_DEBUG_DRAW draws control zones, mode tint, and active touches.
TOUCHDECK_DEBUG_ALPHA=0
TOUCHDECK_DEBUG_DRAW=false
TOUCHDECK_LOG_TOUCH=false

# Optional JSONL trace recorder for real touch input.
# TOUCHDECK_RECORD_TRACE=/tmp/touchdeck-trace.jsonl

# Safety exit gesture: one-finger tap in the top-left corner.
TOUCHDECK_EXIT_CORNER_ENABLED=true
TOUCHDECK_EXIT_CORNER_RATIO=0.12
TOUCHDECK_EXIT_CORNER_TAP_MS=350
